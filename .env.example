# Para probar sin credenciales y grabar la demostracion local:
CLASSIFIER_OFFLINE_MODE=true

# Para usar Azure OpenAI, cambia OFFLINE_MODE a false y completa:
AZURE_OPENAI_ENDPOINT=https://<tu-recurso>.openai.azure.com/
AZURE_OPENAI_API_KEY=<tu-api-key>
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

CLASSIFIER_TEMPERATURE=0.1
CLASSIFIER_MAX_TOKENS=300
CLASSIFIER_TIMEOUT_SECONDS=15
LOG_LEVEL=INFO

# Aplicacion local / SQLite
DB_PATH=./data/retornar_agent.db
# Genera una clave local con: python scripts/generate_key.py
FIELD_ENCRYPTION_KEY=<pega-aqui-la-clave-generada>
APP_ENV=local

# WhatsApp. En local, SEND_MODE=console no llama a Meta.
WHATSAPP_SEND_MODE=console
WHATSAPP_VERIFY_TOKEN=retornar-local-token
WHATSAPP_APP_SECRET=retornar-local-secret
WHATSAPP_ACCESS_TOKEN=<token-meta>
WHATSAPP_PHONE_NUMBER_ID=<phone-number-id>
WHATSAPP_API_VERSION=<version-activa-en-tu-panel-meta>

# Bridge WhatsApp Web/Baileys para demostracion local sin Meta Cloud API
WA_BRIDGE_ENABLED=true
WA_BRIDGE_ALLOW_FROM_ME=false
PYTHON_WS_URL=ws://127.0.0.1:8000/ws/whatsapp
